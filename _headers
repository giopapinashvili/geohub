/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self)
  # Content Security Policy:
  # - script-src: self (Vite bundle) + cdnjs (Font Awesome) + unsafe-inline (theme detection inline script)
  # - connect-src: Firebase services + Cloudinary
  # - img-src: self + Cloudinary + Google avatars + data URIs
  # - frame-src/object-src: blocked entirely
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https://res.cloudinary.com https://lh3.googleusercontent.com https://firebasestorage.googleapis.com https://lh4.googleusercontent.com https://lh5.googleusercontent.com https://lh6.googleusercontent.com https://*.basemaps.cartocdn.com https://*.tile.openstreetmap.org https://tile.openstreetmap.org; font-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://res.cloudinary.com https://api.cloudinary.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://fcmregistrations.googleapis.com https://fcm.googleapis.com https://*.basemaps.cartocdn.com https://*.tile.openstreetmap.org https://tile.openstreetmap.org https://cdn.jsdelivr.net; media-src 'self' blob: https://res.cloudinary.com https://firebasestorage.googleapis.com; worker-src 'self' blob:; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Vite-generated hashed assets: cache forever (content-addressed)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: no-cache

/*.css
  Cache-Control: no-cache

/icons/*
  Cache-Control: public, max-age=31536000, immutable

/admin.html
  Cache-Control: no-cache, no-store, must-revalidate
  X-Robots-Tag: noindex
