rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isAdmin() { return isAuth() && request.auth.token.email == 'gio.papinashvili26@gmail.com'; }
    function isOwner(field) { return isAuth() && request.auth.uid == resource.data[field]; }
    function isOwnerNew(field) { return isAuth() && request.auth.uid == request.resource.data[field]; }

    // ── users ────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create, update, delete: if isAuth() && request.auth.uid == uid;
    }

    // ── posts ────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth()
        && isOwnerNew('authorId')
        && request.resource.data.keys().hasAll(['authorId', 'text', 'createdAt'])
        && request.resource.data.text is string;
      allow update: if isAuth() && (
        isOwner('authorId') ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'commentCount', 'shareCount'])
      );
      allow delete: if isOwner('authorId') || isAdmin();

      match /likes/{uid} {
        allow read: if true;
        allow create, update, delete: if isAuth() && request.auth.uid == uid;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth() && isOwnerNew('authorId') && request.resource.data.text is string;
        allow update, delete: if isOwner('authorId') || isAdmin();
      }
    }

    // ── stories ──────────────────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuth() && isOwnerNew('authorId');
      allow update, delete: if isOwner('authorId') || isAdmin();
    }

    // ── follows ──────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == request.resource.data.followerId;
      allow update, delete: if isAuth() && request.auth.uid == resource.data.followerId;
    }

    // ── savedPosts ───────────────────────────────────────────────────
    match /savedPosts/{docId} {
      allow read: if isAuth() && request.auth.uid == resource.data.uid;
      allow create: if isAuth() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if isAuth() && request.auth.uid == resource.data.uid;
    }

    // ── groupMembers ─────────────────────────────────────────────────
    match /groupMembers/{docId} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if isAuth() && request.auth.uid == resource.data.uid;
    }

    // ── eventParticipants ────────────────────────────────────────────
    match /eventParticipants/{docId} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if isAuth() && request.auth.uid == resource.data.uid;
    }

    // ── friendRequests ───────────────────────────────────────────────
    match /friendRequests/{docId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.fromId ||
        request.auth.uid == resource.data.toId
      );
      allow create: if isAuth() && request.auth.uid == request.resource.data.fromId;
      allow update: if isAuth() && request.auth.uid == resource.data.toId;
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.fromId ||
        request.auth.uid == resource.data.toId
      );
    }

    // ── checkins ─────────────────────────────────────────────────────
    match /checkins/{checkinId} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if isOwner('authorId') || isAdmin();
    }

    // ── notifications ────────────────────────────────────────────────
    // Only admin can create removal notices. Users can read/update only their own notices.
    match /userNotifications/{notifId} {
      allow read: if isAuth() && request.auth.uid == resource.data.toUserId;
      allow create: if isAdmin()
        && request.resource.data.toUserId is string
        && request.resource.data.type is string;
      allow update: if isAuth()
        && request.auth.uid == resource.data.toUserId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    // Default deny for anything not explicitly handled.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
