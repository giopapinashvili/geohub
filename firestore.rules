rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function isOwner(userId) { return signedIn() && uid() == userId; }
    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(uid()));
    }

    function newOwnerMatches() {
      return signedIn() && (
        request.resource.data.get('userId', '') == uid() ||
        request.resource.data.get('authorId', '') == uid() ||
        request.resource.data.get('uid', '') == uid() ||
        request.resource.data.get('createdBy', '') == uid() ||
        request.resource.data.get('ownerId', '') == uid()
      );
    }

    function existingOwnerMatches() {
      return signedIn() && (
        resource.data.get('userId', '') == uid() ||
        resource.data.get('authorId', '') == uid() ||
        resource.data.get('uid', '') == uid() ||
        resource.data.get('createdBy', '') == uid() ||
        resource.data.get('ownerId', '') == uid()
      );
    }

    function onlyCountersChanged() {
      return signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'likeCount', 'commentCount', 'shareCount', 'reactionCount', 'saveCount', 'updatedAt'
      ]);
    }

    function onlyBusinessCountersChanged() {
      return signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'followerCount', 'postCount', 'reviewCount', 'ratingAverage', 'ratingTotal', 'updatedAt'
      ]);
    }

    function onlyGroupCountersChanged() {
      return signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'memberCount', 'postCount', 'updatedAt'
      ]);
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && uid() in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      // Allow any signed-in user to increment pointsBalance (for peer transfers).
      // Points are non-cash loyalty credits — an inflated balance has no monetary value.
      // TODO: move point transfers to Cloud Functions to enforce daily caps server-side.
      allow update: if isOwner(userId) || isAdmin()
        || (signedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pointsBalance', 'updatedAt'])
            && request.resource.data.get('pointsBalance', 0) >= resource.data.get('pointsBalance', 0));
      allow delete: if isAdmin();
      match /challengeProgress/{challengeId} {
        // TODO: For production XP/badge integrity, move challenge evaluation to Cloud Functions
        // (Firestore trigger on checkins/{id}). Client-side transactions prevent concurrent races
        // but a modified client can still bypass field validation. Cloud Functions would own
        // all progress writes and make these rules read-only for the owner.
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
          && (request.resource.data.get('userId', '') == userId || request.resource.data.get('uid', '') == userId)
          && request.resource.data.get('challengeId', '') == challengeId;
        allow update: if isOwner(userId)
          && (resource.data.get('userId', '') == userId || resource.data.get('uid', '') == userId)
          && (request.resource.data.get('userId', '') == userId || request.resource.data.get('uid', '') == userId)
          && request.resource.data.get('challengeId', '') == challengeId
          && request.resource.data.get('count', 0) >= resource.data.get('count', 0)
          && request.resource.data.get('progress', 0) >= resource.data.get('progress', 0)
          && !(resource.data.get('completed', false) == true && request.resource.data.get('completed', false) != true)
          && !(resource.data.get('xpAwarded', false) == true && request.resource.data.get('xpAwarded', false) != true);
        allow delete: if isAdmin();
        match /sources/{sourceId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow delete: if isAdmin();
        }
      }
      match /badges/{badgeId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }
      match /private/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
      // FCM push tokens — user owns their own tokens, admin can read for broadcast
      match /fcmTokens/{token} { allow read: if isOwner(userId) || isAdmin(); allow write: if isOwner(userId); }
    }

    // Admin UIDs are managed in Firestore. Create admins/{uid} manually from Firebase Console before publishing this rule.
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update: if isAdmin() || existingOwnerMatches() || onlyCountersChanged();
      allow delete: if isAdmin() || existingOwnerMatches();
      match /comments/{commentId} {
        allow read: if true;
        allow create: if newOwnerMatches() && request.resource.data.get('text', '') is string;
        allow update, delete: if isAdmin() || existingOwnerMatches();
        match /replies/{replyId} {
          allow read: if true;
          allow create: if newOwnerMatches() && request.resource.data.get('text', '') is string;
          allow update, delete: if isAdmin() || existingOwnerMatches();
        }
      }
      match /likes/{userId} { allow read: if true; allow create, update, delete: if isOwner(userId); }
      match /reactions/{userId} { allow read: if true; allow create, update, delete: if isOwner(userId); }
    }

    match /stories/{storyId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /checkins/{checkinId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /places/{placeId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }

    match /businesses/{businessId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update: if isAdmin() || existingOwnerMatches() || onlyBusinessCountersChanged();
      allow delete: if isAdmin() || existingOwnerMatches();
    }
    match /businessAdmins/{adminId} { allow read: if true; allow create: if signedIn() && request.resource.data.get('userId', '') == uid(); allow update, delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid()); }
    match /businesses/{businessId}/qrScanLogs/{logId} {
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow read: if isAdmin() || (signedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.get('ownerId', '') == uid());
      allow update, delete: if isAdmin();
    }
    match /businessFollowers/{followId} { allow read: if true; allow create: if signedIn() && request.resource.data.get('userId', '') == uid(); allow update: if false; allow delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid()); }
    match /businessReviews/{reviewId} { allow read: if true; allow create: if signedIn() && request.resource.data.get('userId', '') == uid(); allow update, delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid()); }
    match /businessOffers/{offerId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /businessAnalytics/{analyticsId} { allow read: if isAdmin() || (signedIn() && resource.data.get('ownerId', '') == uid()); allow create, update: if signedIn() && request.resource.data.get('ownerId', '') == uid(); allow delete: if isAdmin(); }

    match /follows/{followId} { allow read: if true; allow create: if signedIn() && request.resource.data.keys().hasAll(['followerId','followingId','createdAt']) && request.resource.data.get('followerId', '') == uid() && request.resource.data.get('followingId', '') != uid(); allow update: if false; allow delete: if isAdmin() || (signedIn() && (resource.data.get('followerId', '') == uid() || resource.data.get('followingId', '') == uid())); }
    match /savedPosts/{saveId} { allow read: if signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid() || isAdmin()); allow create: if signedIn() && (request.resource.data.get('userId', '') == uid() || request.resource.data.get('uid', '') == uid()); allow update: if false; allow delete: if isAdmin() || (signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid())); }
    match /savedItems/{itemId} { allow read: if signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid() || isAdmin()); allow create: if signedIn() && (request.resource.data.get('userId', '') == uid() || request.resource.data.get('uid', '') == uid()); allow update: if false; allow delete: if isAdmin() || (signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid())); }

    match /groups/{groupId} { allow read: if true; allow create: if newOwnerMatches(); allow update: if isAdmin() || existingOwnerMatches() || onlyGroupCountersChanged(); allow delete: if isAdmin() || existingOwnerMatches(); }
    match /groupMembers/{memberId} { allow read: if true; allow create: if signedIn() && (request.resource.data.get('userId', '') == uid() || request.resource.data.get('uid', '') == uid()); allow update, delete: if isAdmin() || (signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid())); }
    match /groupPosts/{postId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches() || onlyCountersChanged(); }
    match /groupJoinRequests/{requestId} { allow read: if signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('toUserId', '') == uid() || isAdmin()); allow create: if signedIn() && request.resource.data.get('userId', '') == uid(); allow update: if isAdmin(); allow delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid()); }

    match /events/{eventId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /eventParticipants/{participantId} { allow read: if true; allow create: if signedIn() && (request.resource.data.get('userId', '') == uid() || request.resource.data.get('uid', '') == uid()); allow update, delete: if isAdmin() || (signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid())); }

    match /friendRequests/{requestId} { allow read: if signedIn() && (resource.data.get('fromUserId', '') == uid() || resource.data.get('toUserId', '') == uid() || isAdmin()); allow create: if signedIn() && request.resource.data.keys().hasAll(['fromUserId','toUserId','status','createdAt']) && request.resource.data.get('fromUserId', '') == uid() && request.resource.data.get('toUserId', '') != uid() && request.resource.data.get('status', '') == 'pending'; allow update, delete: if isAdmin() || (signedIn() && (resource.data.get('fromUserId', '') == uid() || resource.data.get('toUserId', '') == uid())); }
    match /friends/{friendId} { allow read: if true; allow create: if signedIn() && uid() in request.resource.data.users; allow update: if false; allow delete: if isAdmin() || (signedIn() && uid() in resource.data.users); }

    match /conversations/{conversationId} {
      allow create: if signedIn() && uid() in request.resource.data.participants;
      allow read, update, delete: if isAdmin() || (signedIn() && uid() in resource.data.participants);
      match /messages/{messageId} {
        allow read: if isAdmin() || isConversationParticipant(conversationId);
        allow create: if isAdmin() || (isConversationParticipant(conversationId) && request.resource.data.senderId == uid());
        allow update: if isAdmin()
          || (signedIn() && resource.data.senderId == uid())
          || (isConversationParticipant(conversationId)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy','deletedFor','updatedAt']));
        allow delete: if isAdmin() || (signedIn() && resource.data.senderId == uid());
      }
    }

    match /messageReactions/{reactionId} {
      // Read is intentionally broad for signed-in users. toggleMessageReaction() first reads a
      // deterministic reaction doc; if it does not exist yet, participant-based read rules can
      // reject that lookup before the app can create it, causing permission-denied.
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.get('userId', '') == uid()
        && request.resource.data.get('conversationId', '') is string
        && request.resource.data.get('messageId', '') is string
        && request.resource.data.get('emoji', '') is string
        && request.resource.data.keys().hasOnly(['conversationId','messageId','userId','emoji','createdAt','updatedAt'])
        && exists(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId))
        && uid() in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participants;
      allow update: if signedIn()
        && resource.data.get('userId', '') == uid()
        && request.resource.data.get('userId', '') == uid()
        && request.resource.data.get('conversationId', '') == resource.data.get('conversationId', '')
        && request.resource.data.get('messageId', '') == resource.data.get('messageId', '')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['emoji','updatedAt']);
      allow delete: if signedIn() && resource.data.get('userId', '') == uid();
    }

    match /chats/{chatId} { allow create: if signedIn() && uid() in request.resource.data.participants; allow read, update, delete: if isAdmin() || (signedIn() && uid() in resource.data.participants); match /messages/{messageId} { allow read, create: if isAdmin() || (signedIn() && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.participants); allow update, delete: if isAdmin() || (signedIn() && resource.data.senderId == uid()); } }

    match /userNotifications/{notificationId} { allow read: if signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('toUserId', '') == uid() || isAdmin()); allow create: if isAdmin() || (signedIn() && request.resource.data.get('fromUserId', '') == uid() && (request.resource.data.get('userId', '') != uid() || request.resource.data.get('toUserId', '') != uid())); allow update: if isAdmin() || (signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('toUserId', '') == uid()) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'seen', 'openedAt', 'updatedAt'])); allow delete: if isAdmin(); }

    match /reviews/{reviewId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /placeReviews/{reviewId} { allow read: if true; allow create: if signedIn() && request.resource.data.get('userId', '') == uid(); allow update, delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid()); }

    // GeoPoints economy: client-side MVP. For high-value campaigns, move awarding/redemption to Cloud Functions.
    match /pointEarnRequests/{requestId} {
      allow read: if signedIn() && (resource.data.get('userId', '') == uid() || isAdmin());
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid() && request.resource.data.get('status', '') == 'pending';
      allow update, delete: if isAdmin();
    }

    match /pointTransactions/{transactionId} {
      allow read: if signedIn() && (uid() in resource.data.participantIds || isAdmin());
      allow create: if signedIn() && (
        isAdmin() ||
        (
          request.resource.data.get('amount', 0) > 0 &&
          request.resource.data.get('amount', 0) <= 10000 &&
          uid() in request.resource.data.participantIds &&
          request.resource.data.get('type', '') in ['gift', 'spend', 'redeem'] &&
          request.resource.data.get('fromUserId', '') == uid()
        )
      );
      allow update, delete: if isAdmin();
    }

    match /rewards/{rewardId} {
      allow read: if true;
      allow create: if isAdmin() || newOwnerMatches();
      allow update: if isAdmin() || existingOwnerMatches();
      allow delete: if isAdmin() || existingOwnerMatches();
    }

    match /rewardCoupons/{couponId} {
      allow read: if signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('businessOwnerId', '') == uid() || isAdmin());
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update: if isAdmin() || (signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('businessOwnerId', '') == uid()) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','usedAt','usedBy','updatedAt']));
      allow delete: if isAdmin();
    }
    match /rewardClaims/{claimId} { allow create: if signedIn() && (request.resource.data.get('userId', '') == uid() || request.resource.data.get('uid', '') == uid()); allow read, update, delete: if isAdmin() || (signedIn() && (resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid())); }
    match /userRewards/{userRewardId} {
      allow read: if signedIn() && (resource.data.get('userId', '') == uid() || isAdmin());
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /reports/{reportId} { allow create: if signedIn(); allow read, update, delete: if isAdmin(); }
    match /hiddenPosts/{hiddenId} { allow read: if signedIn() && (resource.data.get('userId', '') == uid() || isAdmin()); allow create: if signedIn() && request.resource.data.get('userId', '') == uid(); allow update: if false; allow delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid()); }
    match /blockedUsers/{blockId} { allow read: if signedIn() && (resource.data.get('blockerId', '') == uid() || isAdmin()); allow create: if signedIn() && request.resource.data.get('blockerId', '') == uid(); allow update: if false; allow delete: if isAdmin() || (signedIn() && resource.data.get('blockerId', '') == uid()); }
    match /userBadges/{badgeId} { allow read: if true; allow create: if signedIn() && (request.resource.data.get('userId', '') == uid() || isAdmin()); allow update, delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid()); }

    match /admin/{docId} { allow read, write: if isAdmin(); }
    match /challenges/{docId} { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /services/{docId} { allow read: if true; allow create: if isAdmin() || newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /realEstateListings/{docId} { allow read: if true; allow create: if isAdmin() || newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /learningItems/{docId} { allow read: if true; allow create: if isAdmin() || newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /creators/{docId} { allow read: if true; allow create: if isAdmin() || newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /liveActivity/{docId} { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /collections/{collectionId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /routes/{routeId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }

    match /userUiState/{stateId} { allow read: if signedIn() && (resource.data.get('uid', '') == uid() || isAdmin()); allow create: if signedIn() && request.resource.data.get('uid', '') == uid(); allow update: if signedIn() && (resource.data.get('uid', '') == uid() || isAdmin()) && request.resource.data.get('uid', '') == resource.data.get('uid', ''); allow delete: if signedIn() && (resource.data.get('uid', '') == uid() || isAdmin()); }
    match /adminFlags/{flagId} { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /messages/{messageId} { allow read: if isAdmin() || (signedIn() && (resource.data.get('senderId', '') == uid() || resource.data.get('userId', '') == uid() || resource.data.get('recipientId', '') == uid())); allow create: if signedIn() && (request.resource.data.get('senderId', '') == uid() || request.resource.data.get('userId', '') == uid() || request.resource.data.get('createdBy', '') == uid()); allow update, delete: if isAdmin() || (signedIn() && (resource.data.get('senderId', '') == uid() || resource.data.get('userId', '') == uid())); }
    match /tickets/{docId} { allow create: if newOwnerMatches(); allow read, update, delete: if isAdmin() || existingOwnerMatches(); }
    // Stripe payment sessions — written by Cloudflare Worker (admin), read by ticket owner
    match /payments/{paymentId} { allow read: if isAdmin() || existingOwnerMatches(); allow create, update: if isAdmin(); allow delete: if isAdmin(); }
    // Event tickets issued after successful payment — written by Cloudflare Worker (admin)
    match /eventTickets/{ticketId} { allow read: if isAdmin() || existingOwnerMatches(); allow create, update: if isAdmin(); allow delete: if isAdmin(); }
    // Business Premium subscriptions (sub-collection)
    match /businesses/{businessId}/subscriptions/{subId} { allow read: if isAdmin() || (signedIn() && resource.data.get('ownerId','') == uid()); allow create, update, delete: if isAdmin(); }
    match /campaigns/{docId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /collabOffers/{docId} { allow create: if newOwnerMatches(); allow read, update, delete: if isAdmin() || existingOwnerMatches(); }
    match /serviceRequests/{docId} { allow create: if newOwnerMatches(); allow read, update, delete: if isAdmin() || existingOwnerMatches(); }
    match /lessonBookings/{docId} { allow create: if newOwnerMatches(); allow read, update, delete: if isAdmin() || existingOwnerMatches(); }
    match /{document=**} { allow read, write: if false; }
  }
}
