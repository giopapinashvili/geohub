rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── CORE HELPERS ──────────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function isOwner(userId) {
      return signedIn() && uid() == userId;
    }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Caller's UID appears in at least one standard ownership field of the
    // document being created. Used for create-only guards.
    function newOwnerMatches() {
      return signedIn() && (
        request.resource.data.get('userId',    '') == uid() ||
        request.resource.data.get('authorId',  '') == uid() ||
        request.resource.data.get('uid',       '') == uid() ||
        request.resource.data.get('createdBy', '') == uid() ||
        request.resource.data.get('ownerId',   '') == uid()
      );
    }

    // Caller owns the existing document being read/updated/deleted.
    function existingOwnerMatches() {
      return signedIn() && (
        resource.data.get('userId',    '') == uid() ||
        resource.data.get('authorId',  '') == uid() ||
        resource.data.get('uid',       '') == uid() ||
        resource.data.get('createdBy', '') == uid() ||
        resource.data.get('ownerId',   '') == uid()
      );
    }

    // ── USER FIELD PROTECTION ─────────────────────────────────────────────────

    // Fields that only Cloud Functions or an admin may write on a user document.
    // Blocks economy inflation, trust manipulation, and privilege escalation.
    // This list must stay in sync with userCreateFieldsSafe() below.
    function userAdminOnlyFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'pointsBalance', 'totalPointsEarned', 'totalPointsSpent',
        'totalPointsTransferred', 'totalPointsReceived',
        'xp', 'level', 'trustScore', 'verified',
        'role', 'isAdmin', 'adminLevel', 'premiumUntil',
        'suspended', 'suspendedAt', 'suspendedBy'
      ]);
    }

    // Validates searchHistory field when it is being modified on a user document.
    // Must be a list of at most 10 items. Does not fire when searchHistory is untouched.
    function searchHistoryValid() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['searchHistory'])
        || (request.resource.data.searchHistory is list
            && request.resource.data.searchHistory.size() <= 10);
    }

    // On creation a new user document must not include any admin/economy field.
    // Prevents bootstrapping an elevated account before any CF or admin action.
    function userCreateFieldsSafe() {
      return !request.resource.data.keys().hasAny([
        'pointsBalance', 'totalPointsEarned', 'totalPointsSpent',
        'totalPointsTransferred', 'totalPointsReceived',
        'xp', 'level', 'trustScore', 'verified',
        'role', 'isAdmin', 'adminLevel', 'premiumUntil',
        'suspended', 'suspendedAt', 'suspendedBy'
      ]);
    }

    // ── COUNTER HELPERS ───────────────────────────────────────────────────────

    // Social engagement counters updated client-side for MVP.
    // TODO: Move to Cloud Function Firestore triggers for true integrity.
    //       A modified client can currently send arbitrary counter values.
    function onlyCountersChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'likeCount', 'commentCount', 'shareCount',
          'reactionCount', 'saveCount', 'viewCount', 'updatedAt'
        ]);
    }

    // Any signed-in user may update story view fields only (no other fields).
    function onlyStoryViewFields() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['viewedBy', 'viewCount', 'updatedAt']);
    }

    // Fields a post owner/business owner may edit after creation.
    function onlyPostManagementFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'text', 'status', 'visibility', 'commentsDisabled',
        'pinned', 'approvedAt', 'declinedAt', 'updatedAt'
      ]);
    }

    function onlyBusinessCountersChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'followerCount', 'postCount', 'reviewCount',
          'ratingAverage', 'ratingTotal', 'ratingCount',
          'viewCount', 'saveCount', 'quoteCount', 'updatedAt'
        ]);
    }

    // Returns true when the requesting user owns the business at bizId.
    // Uses exists() on businessAdmins rather than a get() to keep cost low.
    function isBizOwner(bizId) {
      return signedIn()
        && exists(/databases/$(database)/documents/businessAdmins/$(bizId + '_' + request.auth.uid));
    }

    // New per-page admin roles live under businesses/{businessId}/admins/{uid}.
    function isBizPageAdmin(bizId) {
      return signedIn()
        && exists(/databases/$(database)/documents/businesses/$(bizId)/admins/$(request.auth.uid));
    }

    // Some older business documents only store ownerId on /businesses/{id}.
    function isBizDocOwner(bizId) {
      return signedIn()
        && exists(/databases/$(database)/documents/businesses/$(bizId))
        && get(/databases/$(database)/documents/businesses/$(bizId)).data.get('ownerId', '') == uid();
    }

    function canManageBiz(bizId) {
      return isAdmin() || isBizOwner(bizId) || isBizPageAdmin(bizId) || isBizDocOwner(bizId);
    }

    function isGroupMember(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid));
    }

    function isGroupManager(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid)).data.get('role', 'member') in ['owner', 'admin', 'moderator'];
    }

    function isGroupOwnerOrAdmin(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid)).data.get('role', 'member') in ['owner', 'admin'];
    }

    // True when the group's privacy field is 'public' (or absent).
    // Used to gate subcollection reads: private/secret group content
    // is only visible to members and admins.
    // If the group document does not exist, get() throws → false (safe deny).
    function isGroupPublic(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data.get('privacy', 'public') == 'public';
    }

    // Business owner of the post's business can moderate comments.
    function isBizOwnerOfPost(postId) {
      let bizId = get(/databases/$(database)/documents/posts/$(postId)).data.get('businessId', '');
      return bizId != '' && canManageBiz(bizId);
    }

    // Post author can moderate (delete) comments on their own post.
    function isPostOwner(postId) {
      let p = get(/databases/$(database)/documents/posts/$(postId)).data;
      return signedIn()
        && (p.get('createdByUid', '') == uid()
            || p.get('authorId',   '') == uid()
            || p.get('userId',     '') == uid());
    }

    function isGroupManagerOfPost() {
      let groupId = resource.data.get('groupId', resource.data.get('targetId', ''));
      return groupId != '' && resource.data.get('targetType', '') == 'group' && isGroupManager(groupId);
    }

    // Comment author may only change text/updatedAt on their own comments.
    function onlyCommentTextChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['text', 'updatedAt']);
    }

    function onlyCommentCountersChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['reactionCount', 'replyCount', 'updatedAt']);
    }

    function onlyCommentSoftDeleteChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'updatedAt'])
        && request.resource.data.get('status', '') in ['active', 'deleted'];
    }

    function onlyPollChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['poll', 'updatedAt']);
    }

    function onlyBusinessReviewCountersChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['reportCount', 'reported', 'updatedAt']);
    }

    function onlyBusinessOwnerReplyChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['ownerReply', 'updatedAt']);
    }

    function onlyMessageParticipantMetaChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likedBy', 'deletedFor', 'deletedForActors', 'seenBy', 'readBy', 'delivered', 'reactions', 'updatedAt']);
    }

    function onlyMessageSenderEditChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'text', 'body', 'message', 'content',
          'edited', 'editedAt', 'deleted', 'deletedBy', 'deletedAt',
          'deletedForEveryone', 'deletedByActorId',
          'status', 'updatedAt',
          'mediaUrl', 'mediaType', 'imageUrl', 'fileName', 'fileSize',
          'attachment', 'attachments', 'replyTo'
        ]);
    }

    function onlyConversationSettingsOwner() {
      return signedIn()
        && request.resource.data.get('userId', '') == uid()
        && request.resource.data.keys().hasOnly([
             'userId', 'conversationId', 'archived', 'mutedUntil', 'theme', 'nickname', 'updatedAt'
           ]);
    }

    function onlyGroupCountersChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberCount', 'postCount', 'updatedAt'
        ]);
    }

    // Reads the conversation doc to verify participant membership.
    // Phase 57: also checks memberUids (canonical) in addition to participants (legacy).
    // Also grants access when the caller is the business owner/customer on a forBusiness conv.
    function isConversationParticipant(conversationId) {
      let convData = get(/databases/$(database)/documents/conversations/$(conversationId)).data;
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && (uid() in convData.participants
            || uid() in convData.get('memberUids', [])
            || (convData.get('forBusiness', false) == true
                && (convData.get('ownerUid', '') == uid()
                    || convData.get('customerUid', '') == uid())));
    }

    // ── USERS ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if true;

      // Create: must be own document; must not pre-set economy or admin fields
      // (those are initialised by Cloud Functions on first sign-in).
      allow create: if isOwner(userId) && userCreateFieldsSafe();

      // Update: owner may edit display/bio fields but never economy or admin
      // fields.  Admin may change anything.  searchHistory must be a list ≤10.
      allow update: if (isOwner(userId) && userAdminOnlyFields() && searchHistoryValid()) || isAdmin();

      allow delete: if isAdmin();

      // ── Challenge progress ──────────────────────────────────────────────────
      // Client writes are allowed for MVP because moving this to Cloud Functions
      // is a significant refactor.  The rules enforce a ratchet (count/progress
      // can only increase) and immutability of the completed/xpAwarded flags.
      //
      // TODO: For full XP integrity, trigger a Cloud Function on checkin creates
      // that owns all progress writes and makes these rules read-only for owner.
      match /challengeProgress/{challengeId} {
        allow read: if isOwner(userId) || isAdmin();

        allow create: if isOwner(userId)
          && (request.resource.data.get('userId', '') == userId
              || request.resource.data.get('uid', '') == userId)
          && request.resource.data.get('challengeId', '') == challengeId
          && request.resource.data.get('count', 0) is number
          && request.resource.data.get('progress', 0) is number;

        allow update: if isOwner(userId)
          // Ownership fields must not change
          && (resource.data.get('userId', '') == userId
              || resource.data.get('uid', '') == userId)
          && (request.resource.data.get('userId', '') == userId
              || request.resource.data.get('uid', '') == userId)
          && request.resource.data.get('challengeId', '') == challengeId
          // Ratchet: count and progress may only increase
          && request.resource.data.get('count',    0) >= resource.data.get('count',    0)
          && request.resource.data.get('progress', 0) >= resource.data.get('progress', 0)
          // These two flags are immutable once set true
          && !(resource.data.get('completed',  false) == true
               && request.resource.data.get('completed',  false) != true)
          && !(resource.data.get('xpAwarded',  false) == true
               && request.resource.data.get('xpAwarded',  false) != true);

        allow delete: if isAdmin();

        match /sources/{sourceId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow delete: if isAdmin();
        }
      }

      // ── Badges (sub-collection) ─────────────────────────────────────────────
      // Owner may create their own badge documents (needed for current client
      // award flow after challenge completion).  Field validation prevents
      // self-granting special/rarity flags.  Updates are admin-only so that a
      // badge cannot be upgraded after award.
      //
      // TODO: Move badge creation to a Cloud Function triggered by
      // challengeProgress completions; then change create to admin-only here.
      match /badges/{badgeId} {
        allow read: if true;

        allow create: if isOwner(userId)
          && request.resource.data.get('userId',  '') == userId
          && request.resource.data.get('badgeId', '') == badgeId
          // Prevent self-granting privilege flags
          && !request.resource.data.keys().hasAny([
               'adminGranted', 'special', 'grantedBy'
             ]);

        // Updates are admin-only: no post-hoc badge inflation.
        allow update, delete: if isAdmin();
      }

      match /private/{docId}   { allow read, write: if isOwner(userId) || isAdmin(); }
      match /fcmTokens/{token} {
        allow read:  if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      // ── Life Events sub-collection ────────────────────────────────────────
      match /lifeEvents/{eventId} {
        allow read: if true;
        allow create: if isOwner(userId)
          && request.resource.data.get('label', '') is string
          && request.resource.data.get('label', '').size() > 0;
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /workHistory/{businessId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // Admin UIDs are set manually in the Firebase Console.
    // No public API must ever allow a user to write here.
    match /admins/{adminId} {
      allow read:                   if isOwner(adminId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── SOCIAL CONTENT ────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if true;
      // Require either text or a media URL so an empty document cannot be used
      // as a fake engagement anchor.
      allow create: if newOwnerMatches()
        && request.resource.data.get('text', '') is string
        && (request.resource.data.get('text', '') != ''
            || request.resource.data.get('mediaUrl', '') != ''
            || request.resource.data.get('mediaUrls', []).size() > 0
            // Poll/share posts may have no normal caption text
            || request.resource.data.get('type', '') == 'poll'
            || request.resource.data.get('sharedPostId', '') != '')
        // If the post claims a businessId:
        //  - visitors posting as themselves (authorType == 'user') are allowed on any business page
        //  - posting as the business identity (authorType == 'business') requires being the biz owner/admin
        && (request.resource.data.get('businessId', '') == ''
            || request.resource.data.get('authorType', 'user') == 'user'
            || canManageBiz(request.resource.data.get('businessId', '')));
      allow update: if isAdmin()
        || onlyCountersChanged()
        || onlyPollChanged()
        || (existingOwnerMatches() && onlyPostManagementFields())
        // Business owner/page admin may manage any post on their page.
        || (canManageBiz(resource.data.get('businessId', ''))
            && resource.data.get('businessId', '') != ''
            && onlyPostManagementFields())
        // Group owner/admin/moderator may approve, decline, pin, or soft-delete group posts.
        || (isGroupManagerOfPost() && onlyPostManagementFields());
      allow delete: if isAdmin()
        || existingOwnerMatches()
        || (canManageBiz(resource.data.get('businessId', ''))
            && resource.data.get('businessId', '') != '')
        || isGroupManagerOfPost();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if newOwnerMatches()
          && request.resource.data.get('text', '') is string
          && request.resource.data.get('text', '').size() > 0;
        // Authors may edit text or soft-delete their own comments; counters are updated by reactions/replies.
        allow update: if isAdmin()
          || onlyCommentCountersChanged()
          || (existingOwnerMatches() && (onlyCommentTextChanged() || onlyCommentSoftDeleteChanged()))
          || isBizOwnerOfPost(postId);
        allow delete: if isAdmin() || existingOwnerMatches() || isBizOwnerOfPost(postId) || isPostOwner(postId);

        match /reactions/{rxUserId} {
          allow read: if true;
          allow create, update: if isOwner(rxUserId)
            && request.resource.data.get('userId', rxUserId) == uid();
          allow delete: if isAdmin() || isOwner(rxUserId);
        }

        match /replies/{replyId} {
          allow read: if true;
          allow create: if newOwnerMatches()
            && request.resource.data.get('text', '') is string
            && request.resource.data.get('text', '').size() > 0;
          allow update, delete: if isAdmin() || existingOwnerMatches() || isBizOwnerOfPost(postId) || isPostOwner(postId);
        }
      }

      // Each like/reaction/poll/view doc ID is the user's own UID — self-only write.
      match /likes/{likeUserId}     { allow read: if true; allow create, update, delete: if isOwner(likeUserId); }
      match /reactions/{rxUserId}   { allow read: if true; allow create, update, delete: if isOwner(rxUserId); }
      match /pollVotes/{voteUserId} {
        allow read: if true;
        allow create: if isOwner(voteUserId)
          && request.resource.data.get('userId', voteUserId) == uid()
          && request.resource.data.get('optionId', '') is string;
        // Allow changing vote: only optionId and updatedAt may change
        allow update: if isOwner(voteUserId)
          && request.resource.data.get('optionId', '') is string
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['optionId', 'updatedAt']);
        allow delete: if isAdmin() || isOwner(voteUserId);
      }
      match /views/{viewerId} {
        allow read: if isAdmin() || isOwner(viewerId) || existingOwnerMatches();
        allow create, update: if isOwner(viewerId)
          && request.resource.data.get('userId', viewerId) == uid();
        allow delete: if isAdmin() || isOwner(viewerId);
      }
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update: if isAdmin() || existingOwnerMatches() || onlyStoryViewFields();
      allow delete: if isAdmin() || existingOwnerMatches();

      match /reactions/{rxUserId} {
        allow read: if true;
        allow create, update: if isOwner(rxUserId);
        allow delete: if isAdmin() || isOwner(rxUserId);
      }

      match /replies/{replyId} {
        allow read: if signedIn();
        allow create: if newOwnerMatches()
          && request.resource.data.get('text', '') is string
          && request.resource.data.get('text', '').size() > 0;
        allow delete: if isAdmin() || existingOwnerMatches();
      }
    }
    match /checkins/{checkinId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /places/{placeId}     { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }

    // ── BUSINESSES ────────────────────────────────────────────────────────────

    match /businesses/{businessId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update: if canManageBiz(businessId) || existingOwnerMatches() || onlyBusinessCountersChanged();
      allow delete: if canManageBiz(businessId) || existingOwnerMatches();

      // ── Services, products, and price list: owner/page-admin CRUD, public read ──
      match /services/{serviceId} {
        allow read: if true;
        allow create, update, delete: if canManageBiz(businessId);
      }
      match /products/{productId} {
        allow read: if true;
        allow create, update, delete: if canManageBiz(businessId);
      }
      match /priceList/{itemId} {
        allow read: if true;
        allow create, update, delete: if canManageBiz(businessId);
      }

      // ── Gallery: owner can CRUD, public read ──────────────────────────
      match /gallery/{photoId} {
        allow read: if true;
        allow create, update, delete: if canManageBiz(businessId);
      }

      // ── Quote requests: any signed-in user can submit (self-attributed).
      // Only the business owner and admins can read them.
      match /quoteRequests/{reqId} {
        allow create: if signedIn()
          && request.resource.data.get('submittedBy', '') == uid()
          && request.resource.data.get('businessId', '') == businessId
          && request.resource.data.get('name',    '') is string
          && request.resource.data.get('message', '') is string;
        allow read: if canManageBiz(businessId)
          || (signedIn() && resource.data.get('submittedBy', '') == uid());
        allow update: if canManageBiz(businessId)
          || (signedIn() && resource.data.get('submittedBy', '') == uid()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
        allow delete: if isAdmin();
      }

      // ── QR scan logs: unchanged ──────────────────────────────────────
      match /qrScanLogs/{logId} {
        allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
        allow read: if canManageBiz(businessId);
        allow update, delete: if isAdmin();
      }
      match /subscriptions/{subId} {
        allow read: if canManageBiz(businessId) || (signedIn() && resource.data.get('ownerId', '') == uid());
        allow create, update, delete: if isAdmin();
      }

      // ── Page Blocks: public can read enabled blocks; only owner/admin can write ──
      match /pageBlocks/{blockId} {
        allow read: if resource.data.get('enabled', true) == true || canManageBiz(businessId);
        allow create, update, delete: if canManageBiz(businessId);
      }

      // Per-page admin roles used by Business Page Pro Tools.
      match /admins/{adminUserId} {
        allow read: if canManageBiz(businessId) || isOwner(adminUserId);
        allow create, update, delete: if isAdmin() || isBizOwner(businessId) || isBizDocOwner(businessId);
      }

      match /events/{eventId} {
        allow read: if true;
        allow create, update, delete: if canManageBiz(businessId);

        match /rsvps/{rsvpUserId} {
          allow read: if true;
          allow create, update: if isOwner(rsvpUserId)
            && request.resource.data.get('userId', rsvpUserId) == uid();
          allow delete: if isAdmin() || isOwner(rsvpUserId) || canManageBiz(businessId);
        }
      }

      match /faq/{faqId} {
        allow read: if true;
        allow create, update, delete: if canManageBiz(businessId);
      }

      match /faqQuestions/{questionId} {
        allow read: if canManageBiz(businessId)
          || (signedIn() && resource.data.get('userId', '') == uid());
        allow create: if signedIn()
          && request.resource.data.get('userId', '') == uid();
        allow update: if canManageBiz(businessId)
          || (signedIn() && resource.data.get('userId', '') == uid()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['question', 'updatedAt']));
        allow delete: if canManageBiz(businessId)
          || (signedIn() && resource.data.get('userId', '') == uid());
      }

      match /milestones/{milestoneId} {
        allow read: if true;
        allow create, update, delete: if canManageBiz(businessId);
      }

      match /analytics/{dateDoc} {
        allow read: if canManageBiz(businessId);
        allow create, update: if signedIn();
        allow delete: if isAdmin();
      }

      match /invites/{inviteId} {
        allow read: if canManageBiz(businessId)
          || (signedIn()
              && (resource.data.get('invitedEmail', '') == request.auth.token.email
                  || resource.data.get('inviteeEmail', '') == request.auth.token.email));
        allow create: if canManageBiz(businessId)
          && request.resource.data.get('businessId', '') == businessId;
        allow update: if canManageBiz(businessId)
          || (signedIn()
              && (resource.data.get('invitedEmail', '') == request.auth.token.email
                  || resource.data.get('inviteeEmail', '') == request.auth.token.email)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']));
        allow delete: if canManageBiz(businessId);
      }

      match /staff/{staffUserId} {
        allow read: if true;
        allow create, update: if canManageBiz(businessId)
          || (isOwner(staffUserId)
              && request.resource.data.get('userId', staffUserId) == uid());
        allow delete: if canManageBiz(businessId) || isOwner(staffUserId);
      }
    }
    match /businessAdmins/{adminId} {
      allow read: if true;
      allow create: if isAdmin()
        || (signedIn()
            && request.resource.data.get('userId', '') == uid()
            && request.resource.data.get('businessId', '') is string
            && request.resource.data.get('businessId', '') != ''
            && get(/databases/$(database)/documents/businesses/$(request.resource.data.get('businessId',''))).data.get('ownerId','') == uid());
      allow update, delete: if isAdmin();
    }
    match /businessFollowers/{followId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update: if false;
      allow delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid());
    }
    match /businessReviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update: if isAdmin()
        || (signedIn() && resource.data.get('userId', '') == uid())
        || onlyBusinessReviewCountersChanged()
        || (canManageBiz(resource.data.get('businessId', '')) && onlyBusinessOwnerReplyChanged());
      allow delete: if isAdmin()
        || (signedIn() && resource.data.get('userId', '') == uid())
        || canManageBiz(resource.data.get('businessId', ''));
    }
    match /businessOffers/{offerId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }
    match /businessAnalytics/{analyticsId} {
      allow read: if isAdmin() || (signedIn() && resource.data.get('ownerId', '') == uid());
      allow create, update: if signedIn() && request.resource.data.get('ownerId', '') == uid();
      allow delete: if isAdmin();
    }

    // ── SOCIAL GRAPH ──────────────────────────────────────────────────────────

    match /follows/{followId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['followerId', 'followingId', 'createdAt'])
        && request.resource.data.get('followerId', '') == uid()
        // Users may not follow themselves
        && request.resource.data.get('followingId', '') != uid();
      allow update: if false;
      allow delete: if isAdmin()
        || (signedIn()
            && (resource.data.get('followerId', '') == uid()
                || resource.data.get('followingId', '') == uid()));
    }
    match /savedPosts/{saveId} {
      allow read: if signedIn()
        && (resource.data.get('userId', '') == uid()
            || resource.data.get('uid', '') == uid()
            || isAdmin());
      allow create: if signedIn()
        && (request.resource.data.get('userId', '') == uid()
            || request.resource.data.get('uid', '') == uid());
      allow update: if false;
      allow delete: if isAdmin()
        || (signedIn()
            && (resource.data.get('userId', '') == uid()
                || resource.data.get('uid', '') == uid()));
    }
    match /savedItems/{itemId} {
      allow read: if signedIn()
        && (resource.data.get('userId', '') == uid()
            || resource.data.get('uid', '') == uid()
            || isAdmin());
      allow create: if signedIn()
        && (request.resource.data.get('userId', '') == uid()
            || request.resource.data.get('uid', '') == uid());
      allow update: if false;
      allow delete: if isAdmin()
        || (signedIn()
            && (resource.data.get('userId', '') == uid()
                || resource.data.get('uid', '') == uid()));
    }

    // ── GROUPS ────────────────────────────────────────────────────────────────

    match /groups/{groupId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update: if isAdmin() || existingOwnerMatches() || isGroupOwnerOrAdmin(groupId) || onlyGroupCountersChanged();
      allow delete: if isAdmin() || existingOwnerMatches() || isGroupOwnerOrAdmin(groupId);

      match /bans/{bannedUserId} {
        allow read: if isAdmin() || isGroupManager(groupId) || isOwner(bannedUserId);
        allow create, update, delete: if isAdmin() || isGroupManager(groupId);
      }

      match /events/{eventId} {
        allow read: if isGroupPublic(groupId) || isGroupMember(groupId) || isAdmin();
        allow create, update, delete: if isAdmin() || isGroupManager(groupId);

        match /rsvps/{rsvpUserId} {
          allow read: if isGroupPublic(groupId) || isGroupMember(groupId) || isAdmin();
          allow create, update: if isOwner(rsvpUserId)
            && request.resource.data.get('userId', rsvpUserId) == uid();
          allow delete: if isAdmin() || isOwner(rsvpUserId) || isGroupManager(groupId);
        }
      }

      match /files/{fileId} {
        allow read: if isGroupPublic(groupId) || isGroupMember(groupId) || isAdmin();
        allow create: if signedIn()
          && request.resource.data.get('uploaderId', '') == uid();
        allow update, delete: if isAdmin()
          || isGroupManager(groupId)
          || (signedIn() && resource.data.get('uploaderId', '') == uid());
      }

      match /chatMessages/{messageId} {
        allow read: if isGroupPublic(groupId) || isGroupMember(groupId) || isAdmin();
        allow create: if signedIn()
          && request.resource.data.get('senderId', '') == uid();
        allow update, delete: if isAdmin()
          || isGroupManager(groupId)
          || (signedIn() && resource.data.get('senderId', '') == uid());
      }
    }
    match /groupMembers/{memberId} {
      allow read: if true;
      allow create: if signedIn()
        && (request.resource.data.get('userId', '') == uid()
            || request.resource.data.get('uid', '') == uid());
      allow update, delete: if isAdmin()
        || (signedIn()
            && (resource.data.get('userId', '') == uid()
                || resource.data.get('uid', '') == uid()))
        || isGroupManager(resource.data.get('groupId', ''));
    }
    match /groupPosts/{postId} {
      // Public-group posts are readable by everyone; private/secret group posts
      // are restricted to members.  groupPrivacy is denormalised onto each post
      // at creation time to avoid a get() per rule evaluation.
      allow read: if resource.data.get('groupPrivacy', 'public') == 'public'
        || isGroupMember(resource.data.get('groupId', ''))
        || isAdmin();
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches() || onlyCountersChanged();
    }
    match /groupJoinRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.get('userId', '') == uid()
            || resource.data.get('toUserId', '') == uid()
            || isGroupManager(resource.data.get('groupId', ''))
            || isAdmin());
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update: if isAdmin() || isGroupManager(resource.data.get('groupId', ''));
      allow delete: if isAdmin()
        || isGroupManager(resource.data.get('groupId', ''))
        || (signedIn() && resource.data.get('userId', '') == uid());
    }

    // ── EVENTS ────────────────────────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /eventParticipants/{participantId} {
      allow read: if true;
      allow create: if signedIn()
        && (request.resource.data.get('userId', '') == uid()
            || request.resource.data.get('uid', '') == uid());
      allow update, delete: if isAdmin()
        || (signedIn()
            && (resource.data.get('userId', '') == uid()
                || resource.data.get('uid', '') == uid()));
    }

    // ── MESSAGING ─────────────────────────────────────────────────────────────

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.get('fromUserId', '') == uid()
            || resource.data.get('toUserId', '') == uid()
            || isAdmin());
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['fromUserId', 'toUserId', 'status', 'createdAt'])
        && request.resource.data.get('fromUserId', '') == uid()
        // Cannot send a request to yourself
        && request.resource.data.get('toUserId', '') != uid()
        && request.resource.data.get('status', '') == 'pending';
      allow update, delete: if isAdmin()
        || (signedIn()
            && (resource.data.get('fromUserId', '') == uid()
                || resource.data.get('toUserId', '') == uid()));
    }
    match /friends/{friendId} {
      allow read: if true;
      allow create: if signedIn() && uid() in request.resource.data.users;
      allow update: if false;
      allow delete: if isAdmin() || (signedIn() && uid() in resource.data.users);
    }

    // ── FRIENDSHIPS (new canonical collection) ────────────────────────────────
    // friendshipId = sorted([uid1, uid2]).join('_')
    match /friendships/{friendshipId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['users', 'user1', 'user2', 'createdAt'])
        && uid() in request.resource.data.users
        // Cannot friend yourself
        && request.resource.data.user1 != request.resource.data.user2;
      allow update: if false;
      allow delete: if isAdmin()
        || (signedIn() && uid() in resource.data.users);
    }

    match /conversations/{conversationId} {
      // Phase 57: also accept memberUids (canonical) alongside legacy participants.
      allow create: if signedIn() && (
        uid() in request.resource.data.participants
        || uid() in request.resource.data.get('memberUids', [])
        || (request.resource.data.get('forBusiness', false) == true
            && (request.resource.data.get('ownerUid', '') == uid()
                || request.resource.data.get('customerUid', '') == uid()))
      );
      allow read, update, delete: if isAdmin()
        || (signedIn() && uid() in resource.data.participants)
        || (signedIn() && uid() in resource.data.get('memberUids', []))
        || (signedIn()
            && resource.data.get('forBusiness', false) == true
            && (resource.data.get('ownerUid', '') == uid()
                || resource.data.get('customerUid', '') == uid()));

      match /messages/{messageId} {
        allow read: if isAdmin() || isConversationParticipant(conversationId);
        // Only a participant may create a message and only as themselves.
        allow create: if isAdmin()
          || (isConversationParticipant(conversationId)
              && request.resource.data.senderId == uid());
        // Sender may edit their own message; any participant may mark it
        // deleted/liked (narrow field allowlist).
        allow update: if isAdmin()
          || (signedIn() && resource.data.senderId == uid() && onlyMessageSenderEditChanged())
          || (isConversationParticipant(conversationId) && onlyMessageParticipantMetaChanged());
        allow delete: if isAdmin()
          || (signedIn() && resource.data.senderId == uid());
      }
    }

    // Message reactions: broad read (needed before the reaction doc exists)
    // but tightly validated on write.
    match /messageReactions/{reactionId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.get('userId', '') == uid()
        && request.resource.data.get('conversationId', '') is string
        && request.resource.data.get('messageId',      '') is string
        && request.resource.data.get('emoji',          '') is string
        && request.resource.data.keys().hasOnly([
             'conversationId', 'messageId', 'userId', 'emoji', 'createdAt', 'updatedAt'
           ])
        && isConversationParticipant(request.resource.data.conversationId);
      allow update: if signedIn()
        && resource.data.get('userId', '') == uid()
        && request.resource.data.get('userId', '') == uid()
        // Immutable fields must not change
        && request.resource.data.get('conversationId', '') == resource.data.get('conversationId', '')
        && request.resource.data.get('messageId',      '') == resource.data.get('messageId',      '')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['emoji', 'updatedAt']);
      allow delete: if signedIn() && resource.data.get('userId', '') == uid();
    }

    match /userConversationSettings/{settingId} {
      allow read: if signedIn()
        && (resource.data.get('userId', '') == uid() || isAdmin());
      allow create, update: if onlyConversationSettingsOwner();
      allow delete: if isAdmin()
        || (signedIn() && resource.data.get('userId', '') == uid());
    }

    match /chats/{chatId} {
      allow create: if signedIn()
        && (uid() in request.resource.data.get('participants', [])
            || uid() in request.resource.data.get('members', []));
      allow read, update, delete: if isAdmin()
        || (signedIn()
            && (uid() in resource.data.get('participants', [])
                || uid() in resource.data.get('members', [])));
      match /messages/{messageId} {
        allow read: if isAdmin()
          || (signedIn()
              && (uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.get('participants', [])
                  || uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.get('members', [])));
        allow create: if isAdmin()
          || (signedIn()
              && (uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.get('participants', [])
                  || uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.get('members', []))
              && (request.resource.data.get('senderId', '') == uid()
                  || request.resource.data.get('userId', '') == uid()
                  || request.resource.data.get('authorId', '') == uid()));
        allow update: if isAdmin()
          || (signedIn() && resource.data.get('senderId', '') == uid() && onlyMessageSenderEditChanged())
          || (signedIn()
              && (uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.get('participants', [])
                  || uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.get('members', []))
              && onlyMessageParticipantMetaChanged());
        allow delete: if isAdmin()
          || (signedIn() && resource.data.get('senderId', '') == uid());
      }
    }

    // Legacy top-level messages collection (kept for back-compat with older
    // message threads; prefer /conversations for new writes).
    match /messages/{messageId} {
      allow read: if isAdmin()
        || (signedIn()
            && (resource.data.get('senderId',    '') == uid()
                || resource.data.get('userId',    '') == uid()
                || resource.data.get('recipientId','') == uid()));
      allow create: if signedIn()
        && (request.resource.data.get('senderId',    '') == uid()
            || request.resource.data.get('userId',   '') == uid()
            || request.resource.data.get('createdBy','') == uid());
      allow update, delete: if isAdmin()
        || (signedIn()
            && (resource.data.get('senderId', '') == uid()
                || resource.data.get('userId', '') == uid()));
    }

    // ── NOTIFICATIONS ─────────────────────────────────────────────────────────

    match /userNotifications/{notificationId} {
      allow read: if signedIn()
        && (resource.data.get('userId',   '') == uid()
            || resource.data.get('toUserId','') == uid()
            || isAdmin());
      allow create: if isAdmin()
        || (signedIn()
            // fromUserId must match the caller (prevents spoofing).
            // Self-notifications (badge, reward) are allowed: userId == toUserId == uid().
            && request.resource.data.get('fromUserId', '') == uid());
      // Recipients may only mark a notification read/seen, nothing else.
      allow update: if isAdmin()
        || (signedIn()
            && (resource.data.get('userId',   '') == uid()
                || resource.data.get('toUserId','') == uid())
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['read', 'seen', 'openedAt', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // ── REVIEWS ───────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }
    match /placeReviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.get('userId', '') == uid());
    }

    // ── ECONOMY ───────────────────────────────────────────────────────────────
    // GeoPoints balances are owned by Cloud Functions for high-value operations.
    // Client-side rules block the most obvious attacks; CF owns all mutations.

    match /dailyTransferTotals/{docId} {
      // Users may only see their own transfer totals.
      allow read:  if signedIn() && resource.data.get('uid', '') == uid();
      allow write: if isAdmin();
    }
    match /pointEarnRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.get('userId', '') == uid() || isAdmin());
      allow create: if signedIn()
        && request.resource.data.get('userId', '') == uid()
        // New requests must start as pending; CF processes them.
        && request.resource.data.get('status', '') == 'pending';
      allow update, delete: if isAdmin();
    }
    match /pointTransactions/{transactionId} {
      // Users can read only transactions they participated in.
      allow read: if signedIn()
        && (uid() in resource.data.participantIds || isAdmin());
      // create/update/delete are admin-only — wallet-doc is the client source of truth.
      // P2P transfers use pointGifts; spendPoints/redeemReward write users/{uid}/private/wallet.
      allow create, update, delete: if isAdmin();
    }

    // ── REWARDS ───────────────────────────────────────────────────────────────

    match /rewards/{rewardId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Admins may change anything.
      // Regular users may decrement quantityRemaining OR stock by exactly 1 when
      // redeeming a reward — all other fields stay unchanged, and only when
      // stock is available.  This keeps the redeem runTransaction working on
      // the Spark plan without Cloud Functions.
      // Both field names are supported because the admin UI writes `stock` while
      // the original schema used `quantityRemaining`.
      allow update: if isAdmin()
        || (signedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantityRemaining', 'updatedAt'])
            && resource.data.get('quantityRemaining', 0) > 0
            && request.resource.data.get('quantityRemaining', 0) == resource.data.get('quantityRemaining', 0) - 1)
        || (signedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt'])
            && resource.data.get('stock', 0) > 0
            && request.resource.data.get('stock', 0) == resource.data.get('stock', 0) - 1);
    }
    match /rewardCoupons/{couponId} {
      allow read: if signedIn()
        && (resource.data.get('userId',          '') == uid()
            || resource.data.get('businessOwnerId','') == uid()
            || isAdmin());
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      // Only the business owner of the reward may mark a coupon used (active → used).
      // Customers cannot self-mark — prevents fraudulent "I already used it" claims.
      // Immutable fields (userId, businessOwnerId, rewardId, code, pointPrice) cannot change.
      allow update: if isAdmin()
        || (signedIn()
            && resource.data.get('businessOwnerId','') == uid()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'usedAt', 'usedBy', 'updatedAt'])
            && request.resource.data.get('status', '') == 'used'
            && resource.data.get('status', '') == 'active');
      allow delete: if isAdmin();
    }
    match /pointGifts/{giftId} {
      allow read: if signedIn()
        && (resource.data.get('fromUserId','') == uid()
            || resource.data.get('toUserId','')   == uid()
            || isAdmin());
      allow create: if signedIn()
        && request.resource.data.get('fromUserId','') == uid()
        && request.resource.data.get('toUserId','')   != uid()
        && request.resource.data.get('status','')     == 'pending'
        && request.resource.data.get('amount', 0)     >  0;
      // Only the recipient may claim (status: pending → claimed).
      allow update: if isAdmin()
        || (signedIn()
            && resource.data.get('toUserId','')   == uid()
            && resource.data.get('status','')     == 'pending'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','claimedAt'])
            && request.resource.data.get('status','') == 'claimed');
      allow delete: if isAdmin();
    }
    match /rewardClaims/{claimId} {
      allow create: if signedIn()
        && (request.resource.data.get('userId', '') == uid()
            || request.resource.data.get('uid',   '') == uid());
      allow read, update, delete: if isAdmin()
        || (signedIn()
            && (resource.data.get('userId', '') == uid()
                || resource.data.get('uid',   '') == uid()));
    }
    // userRewards are awarded by Cloud Functions; users cannot create their own.
    match /userRewards/{userRewardId} {
      allow read: if signedIn()
        && (resource.data.get('userId', '') == uid() || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // ── SAFETY & MODERATION ───────────────────────────────────────────────────

    // Reports: created once by a signed-in user; immutable after that.
    // Status transitions are admin-only (prevents reporter manipulation).
    // Reporters cannot read their own report after submission.
    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasAll([
             'reporterId', 'targetType', 'targetId', 'reason', 'status', 'createdAt'
           ])
        && request.resource.data.get('reporterId', '') == uid()
        // Status must be pending on creation; admin sets resolution.
        && request.resource.data.get('status', '') == 'pending';
      allow read, update, delete: if isAdmin();
    }

    match /hiddenPosts/{hiddenId} {
      allow read: if signedIn()
        && (resource.data.get('userId', '') == uid() || isAdmin());
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update: if false;
      allow delete: if isAdmin()
        || (signedIn() && resource.data.get('userId', '') == uid());
    }

    // The client checks exact block documents before comments/messages, e.g.
    // blockedUsers/{postOwnerId}_{currentUserId}. Firestore also applies rules
    // to non-existent docs; a resource.data-based read rule denies those reads
    // before the app can learn "not blocked". For this MVP we allow signed-in
    // users to read block records, while writes stay owner-only and immutable.
    match /blockedUsers/{blockId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.get('blockerId', '') == uid()
        // Users may not block themselves
        && request.resource.data.get('blockedId', '') != uid();
      // Immutable after creation.
      allow update: if false;
      allow delete: if isAdmin()
        || (signedIn() && resource.data.get('blockerId', '') == uid());
    }

    match /mutedUsers/{muteId} {
      allow read: if signedIn()
        && (resource.data.get('muterId', '') == uid() || isAdmin());
      allow create: if signedIn() && request.resource.data.get('muterId', '') == uid();
      allow update: if false;
      allow delete: if isAdmin()
        || (signedIn() && resource.data.get('muterId', '') == uid());
    }

    // Moderation action log: strictly admin-only (audit trail of decisions).
    match /moderationActions/{actionId} {
      allow read, create, update, delete: if isAdmin();
    }

    // Top-level userBadges collection (display/feed use).
    // Owner may create with field restrictions; updates are admin-only.
    match /userBadges/{badgeId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.get('userId', '') == uid()
        && !request.resource.data.keys().hasAny(['adminGranted', 'special', 'grantedBy']);
      allow update, delete: if isAdmin();
    }

    // ── ADMIN-ONLY COLLECTIONS ────────────────────────────────────────────────

    match /admin/{docId}              { allow read, write: if isAdmin(); }
    match /badges/{badgeId}           { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /challenges/{docId}         { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /services/{docId}           { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /realEstateListings/{docId} { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /learningItems/{docId}      { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /creators/{docId}           { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /liveActivity/{docId}       { allow read: if true; allow create, update, delete: if isAdmin(); }

    // ── USER-GENERATED CONTENT COLLECTIONS ───────────────────────────────────

    match /collections/{collectionId} { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /routes/{routeId}            { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }

    // ── UI STATE & FLAGS ──────────────────────────────────────────────────────

    match /userUiState/{userId} {
      // Document ID is the user's UID — owner-only access.
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /adminFlags/{flagId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── ANALYTICS ─────────────────────────────────────────────────────────────
    // Design: signed-in users write (client-side telemetry), admins read.
    // Unauthenticated requests are always denied — no anonymous tracking.
    // uid fields in error/upload docs must match the caller (no faking errors
    // for another user). Presence docs are owner-only with field validation.

    // Daily aggregate counters (pageViews, searches, events, errors — keyed
    // analytics/{subcol}/daily/{YYYY-MM-DD}).
    match /analytics/{subcol}/daily/{dateDoc} {
      allow read: if isAdmin();
      allow create, update: if signedIn();
    }

    // Presence heartbeats: owner-only with mandatory field validation.
    match /analytics/presence/users/{userId} {
      allow read: if isAdmin();
      allow create, update: if isOwner(userId)
        // uid field must match the document ID (the user's uid)
        && request.resource.data.get('uid',  '') == userId
        && request.resource.data.get('page', '') is string
        && request.resource.data.get('page', '').size() > 0
        && request.resource.data.get('page', '').size() < 100;
    }

    // JS error log: any signed-in user may append (self-reporting).
    // uid field if present must match caller — prevents spoofing another
    // user's identity in an error report.
    match /analytics/errors/log/{docId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.get('message', '') is string
        && request.resource.data.get('page',    '') is string
        && (request.resource.data.get('uid', '') == ''
            || request.resource.data.get('uid', '') == uid());
    }

    // Upload failure log — same uid constraint as errors.
    match /analytics/uploads/failures/{docId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.get('type', '') is string
        && request.resource.data.get('page', '') is string
        && (request.resource.data.get('uid', '') == ''
            || request.resource.data.get('uid', '') == uid());
    }

    // Performance samples: aggregate, no personal data.
    match /analytics/performance/pages/{pageDoc} {
      allow read: if isAdmin();
      allow create, update: if signedIn();
    }

    // ── PAYMENTS & MARKETPLACE ────────────────────────────────────────────────

    match /tickets/{docId}         { allow create: if newOwnerMatches(); allow read, update, delete: if isAdmin() || existingOwnerMatches(); }
    // Payments are written by the Cloudflare Worker (runs as admin); users
    // may read their own payment records only.
    match /payments/{paymentId}    { allow read: if isAdmin() || existingOwnerMatches(); allow create, update, delete: if isAdmin(); }
    match /eventTickets/{ticketId} { allow read: if isAdmin() || existingOwnerMatches(); allow create, update, delete: if isAdmin(); }
    match /campaigns/{docId}       { allow read: if true; allow create: if newOwnerMatches(); allow update, delete: if isAdmin() || existingOwnerMatches(); }
    match /collabOffers/{docId}    { allow create: if newOwnerMatches(); allow read, update, delete: if isAdmin() || existingOwnerMatches(); }
    match /serviceRequests/{docId} { allow create: if newOwnerMatches(); allow read, update, delete: if isAdmin() || existingOwnerMatches(); }
    match /lessonBookings/{docId}  { allow create: if newOwnerMatches(); allow read, update, delete: if isAdmin() || existingOwnerMatches(); }

    // ── SAVED BUSINESSES ─────────────────────────────────────────────────────
    // Document ID convention: {userId}_{businessId}
    match /savedBusinesses/{saveId} {
      allow read: if signedIn()
        && (resource == null
            || resource.data.get('userId', '') == uid()
            || resource.data.get('uid', '') == uid()
            || isAdmin());
      allow create: if signedIn()
        && request.resource.data.get('userId', '') == uid()
        && request.resource.data.get('businessId', '') is string;
      allow update: if false;
      allow delete: if signedIn()
        && (resource.data.get('userId', '') == uid() || isAdmin());
    }

    // ── INVITES & REFERRALS ───────────────────────────────────────────────────
    // Invite codes are created by users and updated only to increment the use
    // counter. The createdBy and code fields are immutable after creation.
    match /invites/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.get('createdBy', '') == uid()
        && request.resource.data.get('uses', -1) == 0;
      // Only the use counter and lastUsedAt timestamp may change.
      allow update: if signedIn()
        && resource.data.get('createdBy', '') != ''
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['uses', 'lastUsedAt']);
      allow delete: if isAdmin();
    }

    // ── DENY-ALL FALLBACK ─────────────────────────────────────────────────────
    // Any collection not explicitly listed above is blocked.
    // This prevents accidental exposure when new collections are added without
    // corresponding rules.
    match /{document=**} { allow read, write: if false; }
  }
}
