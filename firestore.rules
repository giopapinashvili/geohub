rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function isOwner(userId) { return signedIn() && uid() == userId; }
    function isAdmin() {
      return signedIn() && request.auth.token.email in [
        "gio.papinashvili26@gmail.com",
        "gio.papinashvili20@gmail.com"
      ];
    }

    function newOwnerMatches() {
      return signedIn() && (
        request.resource.data.get('userId', '') == uid() ||
        request.resource.data.get('authorId', '') == uid() ||
        request.resource.data.get('uid', '') == uid() ||
        request.resource.data.get('createdBy', '') == uid() ||
        request.resource.data.get('ownerId', '') == uid()
      );
    }

    function existingOwnerMatches() {
      return signedIn() && (
        resource.data.get('userId', '') == uid() ||
        resource.data.get('authorId', '') == uid() ||
        resource.data.get('uid', '') == uid() ||
        resource.data.get('createdBy', '') == uid() ||
        resource.data.get('ownerId', '') == uid()
      );
    }

    function onlyCountersChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'likeCount', 'commentCount', 'shareCount', 'reactionCount', 'saveCount', 'updatedAt'
        ]);
    }

    function onlyBusinessCountersChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'followerCount', 'postCount', 'reviewCount', 'ratingAverage', 'ratingTotal', 'updatedAt'
        ]);
    }

    function onlyGroupCountersChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberCount', 'postCount', 'updatedAt'
        ]);
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && uid() in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    // USERS / PUBLIC PROFILES
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /private/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // POSTS + COMMENTS + LIKES/REACTIONS
    match /posts/{postId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update: if isAdmin() || existingOwnerMatches() || onlyCountersChanged();
      allow delete: if isAdmin() || existingOwnerMatches();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if newOwnerMatches() && request.resource.data.get('text', '') is string;
        allow update, delete: if isAdmin() || existingOwnerMatches();
      }

      match /likes/{userId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId);
      }

      match /reactions/{userId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId);
      }
    }

    // STORIES
    match /stories/{storyId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    // CHECK-INS
    match /checkins/{checkinId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    // PLACES / MAP LOCATIONS
    match /places/{placeId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    // BUSINESSES
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update: if isAdmin() || existingOwnerMatches() || onlyBusinessCountersChanged();
      allow delete: if isAdmin() || existingOwnerMatches();
    }


    // BUSINESS PAGE ADMINS / FOLLOWERS / REVIEWS
    match /businessAdmins/{adminId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update, delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid());
    }

    match /businessFollowers/{followId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update: if false;
      allow delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid());
    }

    match /businessReviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update, delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid());
    }

    // FOLLOWS
    match /follows/{followId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.get('followerId', '') == uid();
      allow update: if false;
      allow delete: if isAdmin()
        || (signedIn() && (
          resource.data.get('followerId', '') == uid() ||
          resource.data.get('followingId', '') == uid() ||
          resource.data.get('targetId', '') == uid()
        ));
    }

    // SAVED POSTS
    match /savedPosts/{saveId} {
      allow read: if signedIn() && (
        resource.data.get('userId', '') == uid() ||
        resource.data.get('uid', '') == uid() ||
        isAdmin()
      );
      allow create: if signedIn() && (
        request.resource.data.get('userId', '') == uid() ||
        request.resource.data.get('uid', '') == uid()
      );
      allow update: if false;
      allow delete: if isAdmin() || (signedIn() && (
        resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid()
      ));
    }

    // GROUPS + MEMBERS + JOIN REQUESTS
    match /groups/{groupId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update: if isAdmin() || existingOwnerMatches() || onlyGroupCountersChanged();
      allow delete: if isAdmin() || existingOwnerMatches();
    }

    match /groupMembers/{memberId} {
      allow read: if true;
      allow create: if signedIn() && (
        request.resource.data.get('userId', '') == uid() || request.resource.data.get('uid', '') == uid()
      );
      allow update, delete: if isAdmin() || (signedIn() && (
        resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid()
      ));
    }

    match /groupPosts/{postId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches() || onlyCountersChanged();
    }

    match /groupJoinRequests/{requestId} {
      allow read: if signedIn() && (
        resource.data.get('userId', '') == uid() || isAdmin()
      );
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid());
      allow update: if isAdmin();
    }

    // EVENTS + PARTICIPANTS
    match /events/{eventId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /eventParticipants/{participantId} {
      allow read: if true;
      allow create: if signedIn() && (
        request.resource.data.get('userId', '') == uid() || request.resource.data.get('uid', '') == uid()
      );
      allow update, delete: if isAdmin() || (signedIn() && (
        resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid()
      ));
    }

    // FRIEND REQUESTS
    match /friendRequests/{requestId} {
      allow read: if signedIn() && (
        resource.data.get('fromUserId', '') == uid() ||
        resource.data.get('fromId', '') == uid() ||
        resource.data.get('toUserId', '') == uid() ||
        resource.data.get('toId', '') == uid() ||
        isAdmin()
      );
      allow create: if signedIn() && (
        request.resource.data.get('fromUserId', '') == uid() || request.resource.data.get('fromId', '') == uid()
      );
      allow update, delete: if isAdmin() || (signedIn() && (
        resource.data.get('fromUserId', '') == uid() ||
        resource.data.get('fromId', '') == uid() ||
        resource.data.get('toUserId', '') == uid() ||
        resource.data.get('toId', '') == uid()
      ));
    }

    // CONVERSATIONS / MESSAGES
    match /conversations/{conversationId} {
      allow create: if signedIn() && uid() in request.resource.data.participants;
      allow read, update, delete: if isAdmin() || (signedIn() && uid() in resource.data.participants);

      match /messages/{messageId} {
        allow read: if isAdmin() || isConversationParticipant(conversationId);
        allow create: if isAdmin() || (isConversationParticipant(conversationId) && request.resource.data.senderId == uid());
        allow update, delete: if isAdmin() || (signedIn() && resource.data.senderId == uid());
      }
    }

    // Backward compatibility for old chats/* code
    match /chats/{chatId} {
      allow create: if signedIn() && uid() in request.resource.data.participants;
      allow read, update, delete: if isAdmin() || (signedIn() && uid() in resource.data.participants);
      match /messages/{messageId} {
        allow read, create: if isAdmin() || (signedIn() && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow update, delete: if isAdmin() || (signedIn() && resource.data.senderId == uid());
      }
    }

    // USER NOTIFICATIONS
    match /userNotifications/{notificationId} {
      allow read: if signedIn() && (
        resource.data.get('userId', '') == uid() || resource.data.get('toUserId', '') == uid() || isAdmin()
      );
      allow create: if isAdmin() || (signedIn() && request.resource.data.get('fromUserId', '') == uid() && (request.resource.data.get('userId', '') != uid() || request.resource.data.get('toUserId', '') != uid()));
      allow update: if isAdmin() || (signedIn() && (
        resource.data.get('userId', '') == uid() || resource.data.get('toUserId', '') == uid()
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'seen', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // REVIEWS (generic)
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    // PLACE REVIEWS
    match /placeReviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.get('userId', '') == uid();
      allow update, delete: if isAdmin() || (signedIn() && resource.data.get('userId', '') == uid());
    }

    // SAVED ITEMS
    match /savedItems/{itemId} {
      allow read: if signedIn() && (
        resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid() || isAdmin()
      );
      allow create: if signedIn() && (
        request.resource.data.get('userId', '') == uid() || request.resource.data.get('uid', '') == uid()
      );
      allow delete: if isAdmin() || (signedIn() && (
        resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid()
      ));
      allow update: if false;
    }

    // REWARDS
    match /rewardClaims/{claimId} {
      allow create: if signedIn() && (
        request.resource.data.get('userId', '') == uid() || request.resource.data.get('uid', '') == uid()
      );
      allow read, update, delete: if isAdmin() || (signedIn() && (
        resource.data.get('userId', '') == uid() || resource.data.get('uid', '') == uid()
      ));
    }

    // REPORTS
    match /reports/{reportId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    // ADMIN
    match /admin/{docId} {
      allow read, write: if isAdmin();
    }


    // ADMIN-MANAGED MARKETPLACE / CONTENT COLLECTIONS
    match /rewards/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /challenges/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /services/{docId} {
      allow read: if true;
      allow create: if isAdmin() || newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /realEstateListings/{docId} {
      allow read: if true;
      allow create: if isAdmin() || newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /learningItems/{docId} {
      allow read: if true;
      allow create: if isAdmin() || newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /creators/{docId} {
      allow read: if true;
      allow create: if isAdmin() || newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /liveActivity/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }


    // FIRESTORE-BACKED UI STATE / PREFERENCES
    match /userUiState/{stateId} {
      allow read: if signedIn() && (resource.data.get('uid', '') == uid() || isAdmin());
      allow create: if signedIn() && request.resource.data.get('uid', '') == uid();
      allow update: if signedIn() && (resource.data.get('uid', '') == uid() || isAdmin())
        && request.resource.data.get('uid', '') == resource.data.get('uid', '');
      allow delete: if signedIn() && (resource.data.get('uid', '') == uid() || isAdmin());
    }

    match /adminFlags/{flagId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // TOP-LEVEL API CLIENT COLLECTIONS
    match /messages/{messageId} {
      allow read: if isAdmin() || (signedIn() && (
        resource.data.get('senderId', '') == uid() ||
        resource.data.get('userId', '') == uid() ||
        resource.data.get('recipientId', '') == uid()
      ));
      allow create: if signedIn() && (
        request.resource.data.get('senderId', '') == uid() ||
        request.resource.data.get('userId', '') == uid() ||
        request.resource.data.get('createdBy', '') == uid()
      );
      allow update, delete: if isAdmin() || (signedIn() && (
        resource.data.get('senderId', '') == uid() ||
        resource.data.get('userId', '') == uid()
      ));
    }

    match /tickets/{docId} {
      allow create: if newOwnerMatches();
      allow read, update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /campaigns/{docId} {
      allow read: if true;
      allow create: if newOwnerMatches();
      allow update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /collabOffers/{docId} {
      allow create: if newOwnerMatches();
      allow read, update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /serviceRequests/{docId} {
      allow create: if newOwnerMatches();
      allow read, update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /lessonBookings/{docId} {
      allow create: if newOwnerMatches();
      allow read, update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /challengeProgress/{docId} {
      allow create: if newOwnerMatches();
      allow read, update, delete: if isAdmin() || existingOwnerMatches();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
