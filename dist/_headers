/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(self)
  # Content Security Policy:
  # - script-src: self (Vite bundle) + cdnjs (Font Awesome) + unsafe-inline (theme detection inline script)
  # - connect-src: Firebase services + Cloudinary + BOG payments Worker
  # - img-src: self + Cloudinary + Google avatars/thumbnails + YouTube thumbs + avatar/QR generators
  # - frame-src: YouTube embeds only (videos/reels playback); object-src blocked
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https://res.cloudinary.com https://lh3.googleusercontent.com https://firebasestorage.googleapis.com https://lh4.googleusercontent.com https://lh5.googleusercontent.com https://lh6.googleusercontent.com https://*.basemaps.cartocdn.com https://basemaps.cartocdn.com https://*.tile.openstreetmap.org https://tile.openstreetmap.org https://openmaptiles.github.io https://cdnjs.cloudflare.com https://*.gstatic.com https://unpkg.com https://fonts.googleapis.com https://fonts.gstatic.com https://i.ytimg.com https://api.dicebear.com https://ui-avatars.com https://picsum.photos https://api.qrserver.com; font-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://res.cloudinary.com https://api.cloudinary.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://fcmregistrations.googleapis.com https://fcm.googleapis.com https://geohub-payments.gio-papinashvili20-bd3.workers.dev https://*.basemaps.cartocdn.com https://basemaps.cartocdn.com https://*.tile.openstreetmap.org https://tile.openstreetmap.org https://cdn.jsdelivr.net https://fonts.openmaptiles.org https://openmaptiles.github.io https://cdnjs.cloudflare.com https://www.gstatic.com https://unpkg.com https://fonts.googleapis.com https://fonts.gstatic.com; media-src 'self' blob: https://res.cloudinary.com https://firebasestorage.googleapis.com; worker-src 'self' blob:; frame-src https://www.youtube.com https://www.youtube-nocookie.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Vite-generated hashed assets: cache forever (content-addressed)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: no-cache

/*.css
  Cache-Control: no-cache

/icons/*
  Cache-Control: public, max-age=31536000, immutable

/admin.html
  Cache-Control: no-cache, no-store, must-revalidate
  X-Robots-Tag: noindex
