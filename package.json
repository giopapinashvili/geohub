{
  "name": "geohub",
  "version": "1.0.0",
  "private": true,
  "description": "GeoHub — Discover Georgia. Static PWA with Firebase backend.",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-static.js",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "serve": "http-server . --port 8080 -c-1 --cors -s"
  },
  "dependencies": {
    "maplibre-gl": "^4.7.1",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "firebase-admin": "^14.1.0",
    "http-server": "^14.1.1",
    "playwright": "^1.60.0",
    "vite": "^6.3.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giopapinashvili/geohub.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/giopapinashvili/geohub/issues"
  },
  "homepage": "https://github.com/giopapinashvili/geohub#readme"
}
