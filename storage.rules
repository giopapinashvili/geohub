rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function isOwner(userId) { return signedIn() && request.auth.uid == userId; }
    function safeImage() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /posts/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && safeImage();
    }
    match /stories/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && safeImage();
    }
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && safeImage();
    }
    match /businesses/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && safeImage();
    }
    match /groups/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && safeImage();
    }
    match /reviews/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && safeImage();
    }
  }
}
